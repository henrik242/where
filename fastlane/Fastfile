default_platform(:ios)

platform :android do
  lane :deploy do
    submit = ENV["SUBMIT_FOR_REVIEW"] != "false"
    upload_to_play_store(
      package_name: "no.synth.where",
      track: "production",
      release_status: submit ? "completed" : "draft",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      mapping: "app/build/outputs/mapping/release/mapping.txt",
      json_key: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH"],
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end

platform :ios do
  lane :build do
    profile_name = ENV["PROFILE_NAME"] || ""
    keychain = ENV["KEYCHAIN_PATH"]

    build_app(
      project: "iosApp/Where.xcodeproj",
      scheme: "Where",
      configuration: "Release",
      export_method: "app-store",
      output_directory: ENV["OUTPUT_DIR"] || "./build",
      output_name: "Where.ipa",
      destination: "generic/platform=iOS",
      skip_profile_detection: true,
      export_options: {
        method: "app-store",
        teamID: "358L7UXVJ4",
        signingStyle: "manual",
        signingCertificate: "iPhone Distribution",
        uploadSymbols: true,
        provisioningProfiles: {
          "no.synth.where" => profile_name
        }
      }
    )
  end

  lane :deploy do
    submit = ENV["SUBMIT_FOR_REVIEW"] != "false"
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    whats_new_en = ENV["WHATS_NEW_EN"] || "Bug fixes and improvements."
    whats_new_no = ENV["WHATS_NEW_NO"] || "Feilrettinger og forbedringer."
    upload_to_app_store(
      api_key: api_key,
      app_identifier: "no.synth.where",
      ipa: ENV["IPA_PATH"],
      skip_screenshots: true,
      skip_metadata: !submit,
      force: true,
      submit_for_review: submit,
      automatic_release: submit,
      precheck_include_in_app_purchases: false,
      release_notes: { "en-US" => whats_new_en, "no" => whats_new_no }
    )
  end
end
