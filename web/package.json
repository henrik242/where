{
  "name": "where-web",
  "version": "1.0.0",
  "description": "Backend server for Where? Android app - live tracking visualization",
  "main": "src/server/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "start": "bun --watch src/server/index.ts",
    "build": "bun build src/client/app.ts --outfile=src/client/app.js --target=browser --minify",
    "test": "bun test",
    "test:unit": "bun test tests/store.test.ts tests/track.test.ts tests/platform.test.ts",
    "test:api": "bun test tests/api.test.ts",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "bunx tsc --noEmit -p tsconfig.server.json && bunx tsc --noEmit -p tsconfig.client.json"
  },
  "keywords": [
    "gps",
    "tracking",
    "norway",
    "maplibre",
    "websocket"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
