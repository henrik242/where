# Server Environment Variables
# Copy this to .env and fill in your values

# Port to run the server on (default: 3000)
PORT=3000

# HMAC secret key for verifying tracking requests
# Generate a secure random string (e.g., using: openssl rand -base64 32)
# This must match the TRACKING_HINT in the Android app build
TRACKING_HINT=your-secret-key-here

# Optional: Admin key for viewing all tracks via web interface
ADMIN_KEY=your-admin-key-here

